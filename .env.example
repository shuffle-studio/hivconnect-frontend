# HIV Connect Central NJ - Frontend Environment Variables

# PayloadCMS Backend URL (required)
# Local development: http://localhost:3000
# Production: https://hivconnect-backend-production.shuffle-seo.workers.dev
PUBLIC_PAYLOAD_URL=http://localhost:3000

# Cloudflare Turnstile site key (get from CF Dashboard → Turnstile → your site)
PUBLIC_TURNSTILE_SITE_KEY=your_site_key_here
